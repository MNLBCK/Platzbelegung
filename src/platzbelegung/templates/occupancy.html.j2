<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Platzbelegung</title>
  <style>
    /* ── Reset & Base ─────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f0f2f5;
      color: #1a1a2e;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ───────────────────────────────────────────────────────── */
    header {
      background: linear-gradient(135deg, #1565c0 0%, #0d47a1 100%);
      color: #fff;
      padding: 1.5rem 2rem;
      box-shadow: 0 2px 8px rgba(0,0,0,.25);
    }
    header h1 { font-size: 1.75rem; font-weight: 700; }
    header .sub {
      margin-top: .25rem;
      font-size: .9rem;
      opacity: .8;
    }
    header .meta {
      margin-top: .5rem;
      font-size: .8rem;
      opacity: .65;
    }

    /* ── Main ─────────────────────────────────────────────────────────── */
    main { flex: 1; padding: 2rem; max-width: 1100px; width: 100%; margin: 0 auto; }

    /* ── Empty state ──────────────────────────────────────────────────── */
    .empty-state {
      background: #fff;
      border-radius: 12px;
      padding: 3rem 2rem;
      text-align: center;
      box-shadow: 0 2px 6px rgba(0,0,0,.08);
      color: #666;
    }
    .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }

    /* ── Venue section ────────────────────────────────────────────────── */
    .venue-section {
      margin-bottom: 2.5rem;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 6px rgba(0,0,0,.08);
      overflow: hidden;
    }
    .venue-header {
      background: linear-gradient(90deg, #1565c0, #1976d2);
      color: #fff;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: .75rem;
    }
    .venue-header .pin { font-size: 1.3rem; }
    .venue-header h2 { font-size: 1.15rem; font-weight: 600; }

    /* ── Day block ────────────────────────────────────────────────────── */
    .day-block { border-top: 1px solid #e8ecf0; }
    .day-block:first-of-type { border-top: none; }
    .day-header {
      background: #f7f9fb;
      padding: .75rem 1.5rem;
      display: flex;
      align-items: center;
      gap: .5rem;
      font-weight: 600;
      font-size: .95rem;
      color: #1565c0;
      border-bottom: 1px solid #e8ecf0;
    }
    .day-header .cal { font-size: 1.1rem; }

    /* ── Games table ──────────────────────────────────────────────────── */
    .games-table { width: 100%; border-collapse: collapse; }
    .games-table thead tr { background: #f0f4f8; }
    .games-table th {
      padding: .5rem 1rem;
      font-size: .8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: #666;
      text-align: left;
      border-bottom: 2px solid #dde3ea;
    }
    .games-table td {
      padding: .65rem 1rem;
      font-size: .9rem;
      border-bottom: 1px solid #eef0f3;
      vertical-align: middle;
    }
    .games-table tbody tr:hover { background: #f7fbff; }
    .games-table tbody tr:last-child td { border-bottom: none; }

    /* Time cells */
    .games-table .time-cell {
      font-family: "SF Mono", "Fira Code", monospace;
      font-size: .85rem;
      white-space: nowrap;
      color: #1565c0;
    }
    .games-table .vs { color: #999; font-size: .8rem; padding: 0 .25rem; }
    .games-table .league-cell { color: #888; font-size: .82rem; }

    /* Training rows */
    .games-table tr.training-row { background: #f0f7ee; }
    .games-table tr.training-row:hover { background: #e4f0e1; }
    .games-table tr.training-row .time-cell { color: #2e7d32; }
    .games-table .training-badge {
      display: inline-block;
      background: #2e7d32;
      color: #fff;
      font-size: .7rem;
      font-weight: 600;
      padding: .1rem .4rem;
      border-radius: 4px;
      margin-right: .4rem;
      vertical-align: middle;
    }
    .games-table .source-link {
      font-size: .75rem;
      color: #2e7d32;
      text-decoration: none;
      margin-left: .4rem;
      opacity: .75;
    }
    .games-table .source-link:hover { opacity: 1; text-decoration: underline; }

    /* ── Footer ───────────────────────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 1.25rem;
      font-size: .8rem;
      color: #888;
      border-top: 1px solid #dde3ea;
      background: #fff;
    }
    footer a { color: #1565c0; text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    /* ── Responsive ───────────────────────────────────────────────────── */
    @media (max-width: 600px) {
      main { padding: 1rem; }
      .games-table th:nth-child(4),
      .games-table td:nth-child(4) { display: none; } /* hide league on small screens */
    }
  </style>
</head>
<body>

<header>
  <h1>⚽ Platzbelegung</h1>
  <p class="sub">Übersicht der Spielbelegung auf Sportplätzen (Quelle: fussball.de)</p>
  {% if generated_at %}
  <p class="meta">Stand: {{ generated_at }}</p>
  {% endif %}
</header>

<main>
{% if venues %}
  {% for entry in venues %}
  <section class="venue-section">
    <div class="venue-header">
      <span class="pin">📍</span>
      <h2>{{ entry.venue }}</h2>
    </div>

    {% for day in entry.days %}
    <div class="day-block">
      <div class="day-header">
        <span class="cal">📅</span>
        {{ day.date_formatted }}
      </div>
      <table class="games-table">
        <thead>
          <tr>
            <th>Von</th>
            <th>Bis</th>
            <th>Partie</th>
            <th>Wettbewerb</th>
          </tr>
        </thead>
        <tbody>
          {% for slot in day.slots %}
          <tr{% if slot.is_training %} class="training-row"{% endif %}>
            <td class="time-cell">{{ slot.start_time.strftime('%H:%M') }}</td>
            <td class="time-cell">{{ slot.end_time.strftime('%H:%M') }}</td>
            <td>
              {% if slot.is_training %}
                <span class="training-badge">Training</span>
                <strong>{{ slot.team_name }}</strong>
                {% if slot.source_url %}
                  <a class="source-link" href="{{ slot.source_url }}" target="_blank" rel="noopener" title="Quelle: {{ slot.source_url }}">↗</a>
                {% endif %}
              {% else %}
                <strong>{{ slot.team_name }}</strong>
                <span class="vs">vs.</span>
                {{ slot.opponent }}
              {% endif %}
            </td>
            <td class="league-cell">{{ slot.league }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endfor %}
  </section>
  {% endfor %}
{% else %}
  <div class="empty-state">
    <div class="icon">📭</div>
    <p>Keine Belegungen im gewählten Zeitraum gefunden.</p>
    <p style="margin-top:.5rem;font-size:.85rem;">
      Bitte zuerst <code>platzbelegung scrape</code> ausführen.
    </p>
  </div>
{% endif %}
</main>

<footer>
  <p>
    Daten werden von
    <a href="https://www.fussball.de" target="_blank" rel="noopener">fussball.de</a>
    abgerufen. Kein offizielles Angebot des DFB.
  </p>
</footer>

</body>
</html>
