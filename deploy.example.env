# Commitbare Beispiel-Konfiguration für das Deploy-Skript.
#
# So verwenden:
#   cp deploy.example.env .deploy.local.env
#   # dann echte Zugangsdaten in .deploy.local.env eintragen
#   bash scripts/deploy.sh
#   # Release erstellen:
#   bash scripts/release.sh v0.1.71
#
# WICHTIG:
# - .deploy.local.env bleibt lokal und wird nicht committed
# - DEPLOY_REMOTE_DIR ist das Zielverzeichnis der Subdomain / des Webroots

# Erlaubte Werte: ftp, ftps, sftp, rsync
DEPLOY_METHOD=ftps

# Hostname des Webservers / FTP-Servers
DEPLOY_HOST=example.org

# Optionaler Port
# FTPS meist 21, SFTP meist 22
DEPLOY_PORT=21

# Benutzername / Passwort nur bei der lokalen Datei mit echten Werten befüllen
DEPLOY_USER=CHANGE_ME
DEPLOY_PASS=CHANGE_ME

# Zielordner auf dem Server, z.B. /www/htdocs/w00abcde/platzbelegung
DEPLOY_REMOTE_DIR=/path/to/subdomain-root

# Optional zusätzlich data/latest.html erzeugen und hochladen
GENERATE_HTML=0

# Konfiguration mit hochladen (für die Web-UI sinnvoll)
UPLOAD_CONFIG=1

# Rewrite-Datei fürs Shared Hosting mit hochladen
UPLOAD_HTACCESS=1

# Nur für FTPS relevant; bei problematischen Hostern notfalls auf false setzen
LFTP_VERIFY_CERTIFICATE=true
